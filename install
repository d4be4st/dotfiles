#!/usr/bin/env bash
# Bootstrap dotfiles on a fresh machine.
# Assumes the repo is already cloned to ~/.dotfiles.

set -e

if ! command -v chezmoi &>/dev/null; then
  echo "Installing chezmoi..."
  brew install chezmoi
fi

chezmoi init --source "$HOME/.dotfiles"
chezmoi apply

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  Manual steps — download these from 1Password:"
echo ""
echo "    ~/.zshenv        → 'zshenv' secure note"
echo "    ~/.ssh/config    → 'ssh config' secure note"
echo "    ~/.ssh/id_rsa    → 'SSH Key' private key"
echo "    ~/.ssh/id_rsa.pub"
echo ""
echo "  Then fix SSH key permissions:"
echo "    chmod 600 ~/.ssh/id_rsa"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
